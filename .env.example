# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# WARNING: Service role key bypasses ALL Row Level Security.
# Only use for local dev. Move to server-side before production.
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com  (restrict to your domain in prod!)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# WARNING: Exposing this client-side allows anyone to send emails on your account.
# Prefer using the Supabase Edge Function (supabase/functions/send-email) instead.
VITE_RESEND_API_KEY=re_your_key_here
VITE_EMAIL_FROM=onboarding@resend.dev
VITE_EMAIL_ENABLED=true

# ─── Blockchain (Hardhat / Sepolia) ─────────────────────────────────────────
# These are server-side only (used by Hardhat deploy scripts, never bundled)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_infura_key
PRIVATE_KEY=your_deployer_private_key_without_0x_prefix

# ─── IPFS (Pinata) ──────────────────────────────────────────────────────────
# WARNING: Exposing the JWT client-side lets anyone pin files to your account.
# Consider using a backend proxy for uploads in production.
VITE_PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=gateway.pinata.cloud

# ─── Smart Contract Addresses (set after deployment) ───────────────────────
VITE_PROPERTY_TOKEN_ADDRESS=
VITE_PROPERTY_REGISTRY_ADDRESS=
VITE_ESCROW_ADDRESS=
VITE_PROPERTY_OFFERS_ADDRESS=
VITE_PROPERTY_NFT_ADDRESS=
